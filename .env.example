# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# OpenRouter
OPENROUTER_API_KEY=sk-or-...
HELICONE_API_KEY=sk-helicone-...
OPENROUTER_PRIMARY_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_FALLBACK_MODEL=google/gemini-flash-1.5
OPENROUTER_BANT_MODEL=google/gemini-flash-1.5

# Redis
REDIS_URL=redis://default:xxxxx@xxxx.railway.internal:6379

# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=eyxxxxxxxxxxxxxxxx

# Helicone (optional)
HELICONE_API_KEY=sk-helicone-xxxxxxxx

# Calendly
CALENDLY_LINK=https://calendly.com/after5-louis/15min

# App
DEBUG=false
INPUT_BUFFER_SECONDS=3
TYPING_DELAY_PER_CHAR=0.03
CHUNK_DELAY_SECONDS=1.5
MAX_FOLLOWUPS=3

# MessageBird
MESSAGEBIRD_API_KEY=your_api_key
MESSAGEBIRD_WORKSPACE_ID=your_workspace_id
MESSAGEBIRD_CHANNEL_ID=your_channel_id

# WhatsApp Cloud API (Meta)
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
WHATSAPP_ACCESS_TOKEN=your_access_token
WHATSAPP_VERIFY_TOKEN=after5_verify_token
MESSAGING_PROVIDER=messagebird

