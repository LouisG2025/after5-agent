{
	"info": {
		"_postman_id": "c1f7b8e3-0d5b-41c6-9c7f-99f57d345e61",
		"name": "After5 Agent Admin",
		"description": "Admin endpoints for managing and testing the After5 AI Sales Agent.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Reset Lead Session",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\\n    \"phone\": \"whatsapp:+910000000000\"\\n}"
				},
				"url": {
					"raw": "{{base_url}}/admin/reset-session",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"admin",
						"reset-session"
					]
				},
				"description": "Clears all Redis session data for a specific lead (history, waiting state, closed state). Albert will treat them as a brand new lead on their next message."
			},
			"response": []
		},
		{
			"name": "Get Lead Status",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/admin/lead-status/whatsapp:+910000000000",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"admin",
						"lead-status",
						"whatsapp:+910000000000"
					]
				},
				"description": "Returns the real-time status, BANT scores, and recent chat history of a lead from both Redis and Supabase."
			},
			"response": []
		},
		{
			"name": "Health Check",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/health",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"health"
					]
				},
				"description": "Checks if the API is running."
			},
			"response": []
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000",
			"type": "string"
		}
	]
}
